{
  "manifest_version": 3,
  "name": "Arc Sidebar Sync",
  "version": "0.1.0",
  "description": "Connect Arc to a local helper and sync sidebar data through OSS.",
  "permissions": [
    "storage",
    "nativeMessaging"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Arc Sidebar Sync"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
